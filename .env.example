# Copy this file to .env for local development
# On Railway, set these as environment variables in the dashboard

ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/onboarding

# Security
FIELD_ENCRYPT_KEY=your-random-32-char-encryption-key-here
SESSION_SECRET=your-random-session-secret-here
ADMIN_PASSWORD=ChangeMe123!
RETENTION_DAYS=1825
SESSION_TIMEOUT_MINS=60

# Sumsub KYB/KYC verification
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
SUMSUB_LEVEL_NAME=basic-kyc-level

PORT=3000
